# ============================================================================
# Google Ads Agent — Buddy by Ahmeego (claude-googleadsagent)
# Environment variables read by the bundled MCP servers.
# ============================================================================
# Copy this file to .env and fill in the values. Claude Code resolves
# ${VAR_NAME} placeholders in .mcp.json at server launch time.
# NEVER commit .env to source control.
# ============================================================================

# ----------------------------------------------------------------------------
# Google Ads API (required for the `google-ads` MCP server and Buddy agent)
# Get these by completing the OAuth flow at:
#   https://www.ahmeego.com/docs/google-ads-auth
# Or follow the wiki: https://github.com/itallstartedwithaidea/claude-googleadsagent/wiki/Authentication
# ----------------------------------------------------------------------------
GOOGLE_ADS_DEVELOPER_TOKEN=your_dev_token_here
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# Optional: pin a specific account to operate against by default.
GOOGLE_ADS_CUSTOMER_ID=

# ----------------------------------------------------------------------------
# Ad Creative MCP (Cloudinary-backed creative validation + optimization)
# Sign up at https://cloudinary.com (free tier is fine for testing)
# ----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----------------------------------------------------------------------------
# Anthropic API key (used by Buddy for orchestration in standalone CLI mode)
# Get one at https://console.anthropic.com
# Inside Claude Code, this is normally not needed.
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ----------------------------------------------------------------------------
# Optional: logging + observability
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
GOOGLEADSAGENT_TELEMETRY=disabled
