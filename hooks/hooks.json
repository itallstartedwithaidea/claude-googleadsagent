{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "run_gaql",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/validate-gaql.js",
            "name": "validate-gaql",
            "description": "Validates GAQL queries to prevent write operations"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/log-tool-call.js",
            "name": "audit-log",
            "description": "Logs all Google Ads tool calls for audit trail"
          }
        ]
      }
    ]
  }
}
